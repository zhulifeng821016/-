rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (required) - Full name
    //   - email: string (optional) - Email address
    //   - role: string (required, enum: ['admin', 'employee']) - User role
    //   - photoUrl: string (optional) - Profile picture URL
    //
    // Collection: tasks
    // Document ID: taskId (Auto-generated)
    // Fields:
    //   - title: string (required) - Task title
    //   - goal: string (optional) - Task goal
    //   - processDetails: list<string> (optional) - Steps
    //   - status: string (required, enum: ['pending', 'in-progress', 'completed'])
    //   - priority: string (required, enum: ['high', 'medium', 'low'])
    //   - assignedToUid: string (required) - UID of assigned employee
    //   - postedAt: timestamp (required) - Creation time
    //   - dueAt: timestamp (optional) - Due time
    //   - createdByUid: string (required) - Admin UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "zhulifeng821016@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'role']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['admin', 'employee'];
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority', 'assignedToUid', 'postedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['pending', 'in-progress', 'completed'] &&
             data.priority in ['high', 'medium', 'low'] &&
             data.assignedToUid is string &&
             data.postedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Only admins can create/update roles. Users can create their own initial profile as employee.
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'employee' || isAdmin());
      
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /tasks/{taskId} {
      // Employees can read tasks assigned to them, admins can read all
      allow read: if isAuthenticated() && (resource.data.assignedToUid == request.auth.uid || isAdmin());
      
      // Only admins can create tasks
      allow create: if isAdmin() && isValidTask(request.resource.data);
      
      // Admins can update any task. Employees can only update status of tasks assigned to them.
      allow update: if isAuthenticated() && (
        isAdmin() && isValidTask(request.resource.data) ||
        (resource.data.assignedToUid == request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
         request.resource.data.status in ['pending', 'in-progress', 'completed'])
      );
      
      // Only admins can delete tasks
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
